# Copy to .env.local for local dev. Add the same variables in Vercel → Settings → Environment Variables.
#
# From Supabase Dashboard → Project Settings → API:
# - Project URL (NOT the /rest/v1 URL)
# - anon public JWT (starts with eyJ — NOT sb_publishable_*)
# - service_role JWT (starts with eyJ — NOT sb_secret_*)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
